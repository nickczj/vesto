APP_PORT=43000
APP_CONTAINER_PORT=3000
SHARED_DOCKER_NETWORK=vesto-shared
HOST=0.0.0.0
PORT=3000
NODE_ENV=production
NUXT_DATABASE_PATH=/data/vesto-v2.db
# Use shared Docker DNS when vesto-go joins SHARED_DOCKER_NETWORK.
NUXT_VESTO_GO_BASE_URL=http://vesto-api:8080
